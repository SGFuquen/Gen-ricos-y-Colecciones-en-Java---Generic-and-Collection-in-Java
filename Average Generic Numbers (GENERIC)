import java.util.Arrays;
import java.util.List;

public class PromedioGenerico {

    public static <T extends Number> double promedio(List<T> lista) {
        if (lista.isEmpty())
            throw new IllegalArgumentException("Lista vacía");

        double suma = 0;
        for (T num : lista) {
            suma += num.doubleValue();
        }
        return suma / lista.size();
    }

    public static void main(String[] args) {
        List<Integer> enteros  = Arrays.asList(10, 20, 30, 40);
        List<Double>  decimales = Arrays.asList(1.5, 2.5, 3.0);
        List<Long>    largos    = Arrays.asList(100L, 200L, 300L);

        System.out.printf("Promedio Integer: %.1f%n", promedio(enteros));
        System.out.printf("Promedio Double:  %.2f%n", promedio(decimales));
        System.out.printf("Promedio Long:    %.1f%n", promedio(largos));
    }
}
